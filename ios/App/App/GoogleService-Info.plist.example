<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Download your real GoogleService-Info.plist from Firebase Console:
  Project settings → Your apps → iOS (bundle id: com.inmaculada.music)
  Save as: ios/App/App/GoogleService-Info.plist
  Then add the file to the App target in Xcode (drag into App folder).
-->
<plist version="1.0">
<dict>
	<key>API_KEY</key>
	<string>YOUR_IOS_API_KEY</string>
	<key>GCM_SENDER_ID</key>
	<string>YOUR_MESSAGING_SENDER_ID</string>
	<key>PLIST_VERSION</key>
	<string>1</string>
	<key>BUNDLE_ID</key>
	<string>com.inmaculada.music</string>
	<key>PROJECT_ID</key>
	<string>inmaculada-music-a391e</string>
	<key>STORAGE_BUCKET</key>
	<string>inmaculada-music-a391e.firebasestorage.app</string>
	<key>IS_ADS_ENABLED</key>
	<false></false>
	<key>IS_ANALYTICS_ENABLED</key>
	<false></false>
	<key>IS_APPINVITE_ENABLED</key>
	<true></true>
	<key>IS_GCM_ENABLED</key>
	<true></true>
	<key>IS_SIGNIN_ENABLED</key>
	<true></true>
	<key>GOOGLE_APP_ID</key>
	<string>1:YOUR_SENDER_ID:ios:YOUR_IOS_APP_ID</string>
</dict>
</plist>
