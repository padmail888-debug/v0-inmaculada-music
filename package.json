{
  "name": "inmaculada-music-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "generate:firebase-sw": "node scripts/generate-firebase-messaging-sw.mjs",
    "native-api-config": "node scripts/write-native-api-config.mjs",
    "dev": "npm run generate:firebase-sw && npm run native-api-config && next dev -p 3000",
    "dev:lan": "npm run generate:firebase-sw && npm run native-api-config && next dev -H 0.0.0.0 -p 3000",
    "adb:reverse": "adb reverse tcp:3000 tcp:3000 && adb reverse tcp:3001 tcp:3001",
    "dev:android": "npm run adb:reverse 2>/dev/null || echo '[dev:android] No device — connect USB, enable debugging, then run: npm run adb:reverse' ; npm run dev:lan",
    "build": "npm run generate:firebase-sw && npm run native-api-config && next build",
    "start": "node scripts/next-start-export-guard.mjs",
    "start:server": "next start",
    "serve:out": "npx --yes serve@latest out -p 3000",
    "lint": "next lint",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "build:clean": "rm -rf .next && npm run build",
    "cap:build:android": "rm -rf .next && npm run build && npx cap sync android",
    "cap:build:android:dev": "rm -rf .next && npm run native-api-config && npm run build && npx cap sync android",
    "cap:build:ios": "rm -rf .next && npm run build && npx cap sync ios"
  },
  "dependencies": {
    "@capacitor-firebase/messaging": "^6.3.1",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.1.0",
    "@capacitor/local-notifications": "^6.1.0",
    "@capacitor/status-bar": "^6.0.3",
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "1.2.2",
    "@radix-ui/react-alert-dialog": "1.1.4",
    "@radix-ui/react-aspect-ratio": "1.1.1",
    "@radix-ui/react-avatar": "1.1.2",
    "@radix-ui/react-checkbox": "1.1.3",
    "@radix-ui/react-collapsible": "1.1.2",
    "@radix-ui/react-context-menu": "2.2.4",
    "@radix-ui/react-dialog": "1.1.4",
    "@radix-ui/react-dropdown-menu": "2.1.4",
    "@radix-ui/react-hover-card": "1.1.4",
    "@radix-ui/react-label": "2.1.1",
    "@radix-ui/react-menubar": "1.1.4",
    "@radix-ui/react-navigation-menu": "1.2.3",
    "@radix-ui/react-popover": "1.1.4",
    "@radix-ui/react-progress": "1.1.1",
    "@radix-ui/react-radio-group": "1.2.2",
    "@radix-ui/react-scroll-area": "1.2.2",
    "@radix-ui/react-select": "2.1.4",
    "@radix-ui/react-separator": "1.1.1",
    "@radix-ui/react-slider": "1.2.2",
    "@radix-ui/react-slot": "1.1.1",
    "@radix-ui/react-switch": "1.1.2",
    "@radix-ui/react-tabs": "1.1.2",
    "@radix-ui/react-toast": "1.2.4",
    "@radix-ui/react-toggle": "1.1.1",
    "@radix-ui/react-toggle-group": "1.1.1",
    "@radix-ui/react-tooltip": "1.1.6",
    "@stripe/react-stripe-js": "4.0.2",
    "@stripe/stripe-js": "7.9.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@vercel/analytics": "1.3.1",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.0.4",
    "critters": "^0.0.24",
    "date-fns": "4.1.0",
    "embla-carousel-react": "8.5.1",
    "firebase": "^11.8.1",
    "firebase-admin": "^13.4.0",
    "geist": "^1.3.1",
    "input-otp": "1.4.1",
    "lucide-react": "^0.454.0",
    "next": "14.2.25",
    "next-themes": "^0.4.6",
    "react": "^19",
    "react-day-picker": "9.8.0",
    "react-dom": "^19",
    "react-hook-form": "^7.60.0",
    "react-resizable-panels": "^2.1.7",
    "recharts": "2.15.4",
    "sonner": "^1.7.4",
    "stripe": "18.5.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^0.9.9",
    "zod": "3.25.67"
  },
  "devDependencies": {
    "@capacitor/android": "^6.1.0",
    "@capacitor/cli": "^6.1.0",
    "@capacitor/ios": "^6.1.0",
    "@tailwindcss/postcss": "^4.1.9",
    "@types/node": "^22",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "postcss": "^8.5",
    "tailwindcss": "^4.1.9",
    "tw-animate-css": "1.3.3",
    "typescript": "^5"
  }
}
